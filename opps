"Real-time Stock Price Monitor"
- OOP + Async/Await
- OOP + Generators (streaming data)
- OOP + Context Managers
- OOP + Decorators
"""

import asyncio
import random
from contextlib import asynccontextmanager
from dataclasses import dataclass

@dataclass
class Stock:
    symbol: str
    price: float
    
    def update_price(self, new_price):
        self.price = new_price
    
    def __str__(self):
        return f"${self.symbol}: ${self.price:.2f}"

class StockMonitor:
    def __init__(self):
        self.stocks = {}
    
    async def watch_stock(self, symbol, interval=1):
        """Generator that streams price updates"""
        while True:
            if symbol in self.stocks:
                change = random.uniform(-5, 5)
                self.stocks[symbol].update_price(
                    self.stocks[symbol].price + change
                )
                yield self.stocks[symbol]
            await asyncio.sleep(interval)
    
    async def run_monitor(self, symbols):
        """Async monitor for multiple stocks"""
        tasks = []
        for symbol in symbols:
            self.stocks[symbol] = Stock(symbol, random.uniform(10, 100))
            tasks.append(self.watch_stock(symbol))
        
        # Run all monitors concurrently
        while True:
            for task in asyncio.as_completed(tasks):
                stock = await task
                print(f"📊 {stock}")
    
    @asynccontextmanager
    async def stock_session(self):
        """Context manager for monitoring session"""
        print("📈 Starting stock monitor...")
        try:
            yield self
        finally:
            print("📉 Stopping stock monitor...")
            await asyncio.sleep(0.5)

